func multiply(Matrix A, B) -> Matrix {
    const m = A.rows()
    const n = A.columns()
    const o = B.rows()
    const p = B.columns()

    assert(n == o, "A.columns() must equal B.rows()")

    Matrix C(m, p)

    for i in 0..<m {
        for k in 0..<n {
            for j in 0..<p {
                C[i, j] += A[i, k] * B[k, j]
            }
        }
    }

    return C
}