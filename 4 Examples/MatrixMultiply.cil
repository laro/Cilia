func multiply(Matrix A, B) -> Matrix {
    Int m = A.rows()
    Int n = A.columns()
    Int o = B.rows()
    Int p = B.columns()

    assert(n == o, "A.columns() must equal B.rows() for matrix multiplication")

    Matrix C(m, p);

    for i in 0..<m {
        for j in 0..<p {
            for k in 0..<n {
                C[i, j] += A[i, k] * B[k, j]
            }
        }
    }

    return C
}